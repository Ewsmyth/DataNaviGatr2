FROM node:20-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG REACT_APP_API_BASE_URL=
ARG REACT_APP_INGEST_BASE_URL=
ARG REACT_APP_PORTAINER_URL=https://localhost:9443
ARG REACT_APP_MONGO_EXPRESS_URL=http://localhost:8081

ENV REACT_APP_API_BASE_URL=$REACT_APP_API_BASE_URL
ENV REACT_APP_INGEST_BASE_URL=$REACT_APP_INGEST_BASE_URL
ENV REACT_APP_PORTAINER_URL=$REACT_APP_PORTAINER_URL
ENV REACT_APP_MONGO_EXPRESS_URL=$REACT_APP_MONGO_EXPRESS_URL

RUN npm run build

FROM nginx:1.27-alpine

COPY build-nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build /usr/share/nginx/html

EXPOSE 5002
